{
  "info": {
    "name": "Insurance Management Platform API",
    "description": "Complete Postman API Collection for Insurance Management Platform (Auth, Customers, Policies, Claims, Payments, Documents, Reports)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Agent\",\n  \"email\": \"agent@insurance.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"agent\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"agent@insurance.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Get Profile (/me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "Get Customers List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/customers?page=1&limit=10&search=", "host": ["{{baseUrl}}"], "path": ["api", "customers"] }
          }
        },
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Smith\",\n  \"dob\": \"1990-05-15\",\n  \"phone\": \"+91 9876543210\",\n  \"email\": \"alice@example.com\",\n  \"address\": \"123 Park Street, Mumbai\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/customers", "host": ["{{baseUrl}}"], "path": ["api", "customers"] }
          }
        },
        {
          "name": "Get Customer By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/customers/1", "host": ["{{baseUrl}}"], "path": ["api", "customers", "1"] }
          }
        }
      ]
    },
    {
      "name": "Policies",
      "item": [
        {
          "name": "Get Policies List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/policies?page=1&limit=10&status=active", "host": ["{{baseUrl}}"], "path": ["api", "policies"] }
          }
        },
        {
          "name": "Create Policy",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": 1,\n  \"policyType\": \"Health Comprehensive\",\n  \"premiumAmount\": 15000,\n  \"startDate\": \"2026-01-01\",\n  \"endDate\": \"2027-01-01\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/policies", "host": ["{{baseUrl}}"], "path": ["api", "policies"] }
          }
        },
        {
          "name": "Renew Policy (+1 Year)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/policies/1/renew", "host": ["{{baseUrl}}"], "path": ["api", "policies", "1", "renew"] }
          }
        },
        {
          "name": "Cancel Policy",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/policies/1/cancel", "host": ["{{baseUrl}}"], "path": ["api", "policies", "1", "cancel"] }
          }
        }
      ]
    },
    {
      "name": "Claims",
      "item": [
        {
          "name": "Get Claims List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/claims?page=1&limit=10", "host": ["{{baseUrl}}"], "path": ["api", "claims"] }
          }
        },
        {
          "name": "Submit Claim",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policyId\": 1,\n  \"claimAmount\": 25000,\n  \"reason\": \"Hospitalization expense for surgical procedure\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/claims", "host": ["{{baseUrl}}"], "path": ["api", "claims"] }
          }
        },
        {
          "name": "Approve / Reject Claim (Admin / Agent)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/claims/1/status", "host": ["{{baseUrl}}"], "path": ["api", "claims", "1", "status"] }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Get Payments List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/payments?page=1&limit=10", "host": ["{{baseUrl}}"], "path": ["api", "payments"] }
          }
        },
        {
          "name": "Record Premium Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policyId\": 1,\n  \"amount\": 15000,\n  \"paymentDate\": \"2026-07-20\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/payments", "host": ["{{baseUrl}}"], "path": ["api", "payments"] }
          }
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "Get Customer Documents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/documents/customer/1", "host": ["{{baseUrl}}"], "path": ["api", "documents", "customer", "1"] }
          }
        },
        {
          "name": "Download Document",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/documents/1/download", "host": ["{{baseUrl}}"], "path": ["api", "documents", "1", "download"] }
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Get Dashboard Stats (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/reports/dashboard", "host": ["{{baseUrl}}"], "path": ["api", "reports", "dashboard"] }
          }
        },
        {
          "name": "Export PDF Summary Report (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/reports/export/pdf", "host": ["{{baseUrl}}"], "path": ["api", "reports", "export", "pdf"] }
          }
        }
      ]
    }
  ]
}
