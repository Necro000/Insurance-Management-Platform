// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Phase 1 will run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  admin
  agent
  customer
}

enum PolicyStatus {
  active
  expired
  cancelled
}

enum ClaimStatus {
  pending
  approved
  rejected
}

enum PaymentStatus {
  paid
  pending
  overdue
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(customer)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id        Int        @id @default(autoincrement())
  name      String
  dob       DateTime
  phone     String
  address   String
  email     String
  policies  Policy[]
  documents Document[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Policy {
  id            Int              @id @default(autoincrement())
  customerId    Int
  customer      Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  policyType    String
  policyNumber  String           @unique
  premiumAmount Decimal          @db.Decimal(12, 2)
  startDate     DateTime
  endDate       DateTime
  status        PolicyStatus     @default(active)
  claims        Claim[]
  payments      PremiumPayment[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model Claim {
  id             Int         @id @default(autoincrement())
  policyId       Int
  policy         Policy      @relation(fields: [policyId], references: [id], onDelete: Restrict)
  claimAmount    Decimal     @db.Decimal(12, 2)
  reason         String
  status         ClaimStatus @default(pending)
  submissionDate DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model PremiumPayment {
  id            Int           @id @default(autoincrement())
  policyId      Int
  policy        Policy        @relation(fields: [policyId], references: [id], onDelete: Restrict)
  paymentDate   DateTime
  amount        Decimal       @db.Decimal(12, 2)
  paymentStatus PaymentStatus @default(pending)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Document {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  fileName   String
  filePath   String
  uploadedAt DateTime @default(now())
}
